# Project: 737ND
# Makefile created by Red Panda C++ 2.26.2249

CPP      = g++.exe
CC       = gcc.exe
WINDRES  = windres.exe
RES      = 737ND_private.res
OBJ      = DrawFrame.o main.o $(RES)
LINKOBJ  = DrawFrame.o main.o 737ND_private.res
CLEANOBJ  =  DrawFrame.o main.o  737ND_private.res 737ND.exe
LIBS     =  -L"D:/cURL/curl-8.8.0_2-win64-mingw/lib" -s -lgraphics64 -lws2_32 -lgraphics -luuid -lmsimg32 -lgdi32 -limm32 -lole32 -loleaut32 -lwinmm -lgdiplus   -static
INCS     =  
CXXINCS  =  -I"D:/cURL/curl-8.8.0_2-win64-mingw/include" 
BIN      = 737ND.exe
CXXFLAGS = $(CXXINCS)  -O2 -pipe -lgraphics64
CFLAGS   = $(INCS)  -O2 -pipe -lgraphics64
RM       = del /q /f
WINDRESFLAGS  = 

.PHONY: all all-before all-after clean clean-custom

all: all-before $(BIN) all-after

clean: clean-custom
	-$(RM) $(CLEANOBJ) > NUL 2>&1

$(BIN): $(OBJ)
	$(CPP) $(LINKOBJ) -o $(BIN) $(LIBS)

DrawFrame.o: DrawFrame.cpp DrawFrame.h
	$(CPP) -c DrawFrame.cpp -o DrawFrame.o $(CXXFLAGS)  -finput-charset=UTF-8 -fexec-charset=gbk

main.o: main.cpp DrawFrame.h
	$(CPP) -c main.cpp -o main.o $(CXXFLAGS)  -finput-charset=UTF-8 -fexec-charset=gbk

737ND_private.res: 737ND_private.rc 
	$(WINDRES) -i 737ND_private.rc --input-format=rc -o 737ND_private.res -O coff $(WINDRESFLAGS) 

